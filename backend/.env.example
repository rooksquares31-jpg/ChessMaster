# Copy this file to .env and fill in real values
# NEVER commit .env to git

PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/homeworkchecker?appName=Cluster0

# JWT — generate strong random secrets for production
# Run:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<replace-with-64-byte-hex>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<replace-with-different-64-byte-hex>
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Your Vercel frontend URL(s) — set AFTER deploying frontend
# If you have multiple trusted origins, separate them with commas.
# Example: CLIENT_URL=https://your-app.vercel.app,https://preview-your-app.vercel.app
CLIENT_URL=https://your-app.vercel.app

# File uploads
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads
